{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "jsPlugins": ["./packages/eslint-plugin/dist/index.js"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "vincle/no-react-imports": "error",
    "vincle/no-react-hooks": "error",
    "vincle/no-unsafe-event-handlers": "warn",
    "vincle/no-javascript-urls": "error",
    "vincle/no-context": "error",
    "vincle/no-refs": "error",
    "vincle/no-global-jsx-namespace": "error",
    "no-inline-comments": "off",
    "consistent-function-scoping": "off",
    "no-magic-numbers": "off",
    "no-null": "off",
    "no-ternary": "off",
    "sort-keys": "off",
    "sort-imports": "off",
    "id-length": "off",
    "capitalized-comments": "off",
    "func-style": "off",
    "curly": "off",
    "max-statements": "off",
    "max-params": "off",
    "max-lines": "off",
    "max-depth": "off",
    "max-nested-callbacks": "off",
    "init-declarations": "off",
    "no-underscore-dangle": ["warn", { "allow": ["__html", "__brand"] }],
    "unicorn/require-module-specifiers": "off",
    "eslint/no-await-in-loop": "off"
  },
  "overrides": [
    {
      "files": ["apps/**"],
      "rules": {
        "no-explicit-any": "off",
        "no-unsafe-assignment": "off",
        "no-unsafe-member-access": "off",
        "no-unsafe-argument": "off",
        "no-unsafe-return": "off",
        "no-unsafe-call": "off",
        "restrict-template-expressions": "off",
        "no-base-to-string": "off",
        "no-non-null-assertion": "off",
        "no-confusing-void-expression": "off",
        "vincle/no-react-imports": "off",
        "vincle/no-react-hooks": "off",
        "vincle/no-global-jsx-namespace": "off"
      }
    },
    {
      "files": ["apps/bench/**"],
      "rules": {
        "no-new-array": "off"
      }
    },
    {
      "files": ["apps/docs/docs-src/lib/**"],
      "rules": {
        "no-new-array": "off"
      }
    },
    {
      "files": ["apps/docs/docs-src/examples/**"],
      "rules": {
        "no-unused-vars": "off",
        "no-await-in-loop": "off"
      }
    },
    {
      "files": ["packages/eslint-plugin/src/rules/**"],
      "rules": {
        "no-control-regex": "off"
      }
    },
    {
      "files": ["packages/core/src/react-augment.d.ts"],
      "rules": {
        "no-empty-file": "off"
      }
    },
    {
      "files": ["**/*.test.ts", "**/*.test.tsx", "**/*.test-d.ts"],
      "rules": {
        "no-await-in-loop": "off",
        "no-explicit-any": "off",
        "no-non-null-assertion": "off",
        "no-unsafe-assignment": "off",
        "no-unsafe-member-access": "off",
        "no-unsafe-argument": "off",
        "no-unsafe-return": "off",
        "no-unsafe-call": "off",
        "no-confusing-void-expression": "off",
        "no-unused-expressions": "off",
        "no-useless-spread": "off",
        "no-new": "off",
        "require-await": "off",
        "await-thenable": "off",
        "restrict-template-expressions": "off",
        "no-base-to-string": "off",
        "unbound-method": "off",
        "no-unnecessary-condition": "off",
        "no-unnecessary-type-assertion": "off",
        "no-unsafe-enum-comparison": "off",
        "vincle/no-react-imports": "off",
        "vincle/no-react-hooks": "off",
        "vincle/no-unsafe-event-handlers": "off",
        "vincle/no-javascript-urls": "off",
        "vincle/no-context": "off",
        "vincle/no-refs": "off",
        "vincle/no-global-jsx-namespace": "off"
      }
    }
  ],
  "env": {
    "builtin": true
  }
}
