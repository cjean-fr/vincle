{
  "name": "@vincle/vincle",
  "type": "module",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@vincle/core": "workspace:*",
      "@vincle/flow": "workspace:*",
      "@vincle/vite-plugin": "workspace:*",
      "@vincle/precompile-core": "workspace:*",
      "@vincle/vite-plugin-precompile": "workspace:*",
      "@vincle/eslint-plugin": "workspace:*",
      "@iconify-icons/tabler": "^1.2",
      "@tailwindcss/vite": "^4.3.2",
      "@types/bun": "^1.3.14",
      "@types/node": "^22.20.1",
      "@types/react": "^19.2.17",
      "bunup": "^0.16",
      "eslint": "^10.6.0",
      "fast-check": "^3.23.2",
      "gray-matter": "^4.0.3",
      "pkgroll": "^2.27.1",
      "postcss": "^8",
      "shiki": "^4",
      "tailwindcss": "^4.3.2",
      "typescript": "^6.0.3",
      "typescript-eslint": "^8",
      "@typescript-eslint/parser": "^8.63.0",
      "@typescript-eslint/eslint-plugin": "^8",
      "@typescript-eslint/utils": "^8.63.0",
      "@typescript-eslint/rule-tester": "^8.63.0",
      "unified": "^11",
      "vite": "^8.1.4",
      "vite-plugin-dts": "^5",
      "zod": "^4"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@oxc-project/types": "^0.139.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "bun": "^1.3.14",
    "eslint": "^10.6.0",
    "lefthook": "^2.1.10",
    "lint-staged": "^17.0.8",
    "oxc-parser": "^0.139.0",
    "oxc-transform": "^0.139.0",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "turbo": "^2.10.4",
    "typescript-eslint": "^8.63.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "turbo build",
    "check": "turbo check",
    "dev": "turbo run dev",
    "format": "turbo format",
    "test": "turbo test",
    "test:coverage": "bun test --coverage"
  },
  "packageManager": "bun@1.3.10"
}
