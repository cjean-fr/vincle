{
  "name": "@vincle/vincle",
  "type": "module",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@vincle/core": "workspace:*",
      "@vincle/flow": "workspace:*",
      "@vincle/vite-plugin": "workspace:*",
      "@vincle/precompile-core": "workspace:*",
      "@vincle/vite-plugin-precompile": "workspace:*",
      "@vincle/eslint-plugin": "workspace:*",
      "@iconify-icons/tabler": "^1.2",
      "@tailwindcss/vite": "^4",
      "@types/bun": "^1",
      "@types/node": "^22",
      "@types/react": "^19",
      "bunup": "^0.16",
      "eslint": "^10",
      "fast-check": "^3",
      "gray-matter": "^4",
      "pkgroll": "^2",
      "postcss": "^8",
      "shiki": "^4",
      "tailwindcss": "^4",
      "typescript": "^6",
      "typescript-eslint": "^8",
      "@typescript-eslint/parser": "^8",
      "@typescript-eslint/eslint-plugin": "^8",
      "@typescript-eslint/utils": "^8.62.0",
      "@typescript-eslint/rule-tester": "^8",
      "unified": "^11",
      "vite": "^8",
      "vite-plugin-dts": "^5",
      "zod": "^4"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@oxc-project/types": "latest",
    "@tailwindcss/postcss": "latest",
    "@trivago/prettier-plugin-sort-imports": "latest",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "bun": "latest",
    "eslint": "latest",
    "lefthook": "latest",
    "lint-staged": "latest",
    "oxc-parser": "latest",
    "oxc-transform": "latest",
    "prettier": "latest",
    "prettier-plugin-tailwindcss": "latest",
    "tailwindcss": "latest",
    "turbo": "latest",
    "typescript-eslint": "latest"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "turbo build",
    "check": "turbo check",
    "dev": "turbo run dev",
    "format": "turbo format",
    "test": "turbo test",
    "test:coverage": "bun test --coverage"
  },
  "packageManager": "bun@1.3.10"
}
