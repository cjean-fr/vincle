{
  "name": "@vincle/vincle",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@vincle/core": "workspace:*",
      "@vincle/flow": "workspace:*",
      "@vincle/vite-plugin": "workspace:*",
      "@vincle/precompile-core": "workspace:*",
      "@vincle/vite-plugin-precompile": "workspace:*",
      "@vincle/eslint-plugin": "workspace:*",
      "@iconify-icons/tabler": "^1.2",
      "@tailwindcss/vite": "^4.3.2",
      "@types/bun": "^1.3.14",
      "@types/node": "^22.20.1",
      "@types/react": "^19.2.17",
      "bun": "^1.3.14",
      "eslint": "^10.6.0",
      "fast-check": "^3.23.2",
      "gray-matter": "^4.0.3",
      "tsdown": "^0.22.7",
      "postcss": "^8",
      "shiki": "^4",
      "tailwindcss": "^4.3.2",
      "typescript": "^7.0.2",
      "@typescript-eslint/parser": "^8.63.0",
      "@typescript-eslint/utils": "^8.63.0",
      "@typescript-eslint/rule-tester": "^8.63.0",
      "unified": "^11",
      "vite": "^8.1.4",
      "vite-plugin-dts": "^5",
      "zod": "^4"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "check": "turbo check",
    "dev": "turbo run dev",
    "format": "turbo format",
    "lint": "oxlint .",
    "test": "turbo test",
    "test:coverage": "bun test --coverage"
  },
  "devDependencies": {
    "@oxc-project/types": "^0.139.0",
    "@tailwindcss/postcss": "^4.3.2",
    "bun": "^1.3.14",
    "lefthook": "^2.1.10",
    "lint-staged": "^17.0.8",
    "oxc-parser": "^0.139.0",
    "oxc-transform": "^0.139.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tailwindcss": "^4.3.2",
    "turbo": "^2.10.5"
  },
  "peerDependencies": {
    "typescript": "^7.0.2"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "bun@1.3.14"
}
