{
  "name": "@vincle/docs",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun docs-src/dev-server.ts",
    "build": "bun run build:vite && bun run build:ssg",
    "build:vite": "vite build",
    "build:ssg": "bun docs-src/build.tsx",
    "preview": "vite preview --outDir dist",
    "test": "bun test",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@vincle/core": "workspace:*",
    "@vincle/flow": "workspace:*",
    "@vincle/vite-plugin": "workspace:*",
    "gray-matter": "^4",
    "hast-util-to-html": "^9",
    "minimatch": "^10",
    "satteri": "^0.9.1",
    "satteri-expressive-code": "^0.1.17",
    "vite-plugin-satteri": "^0.2.11"
  },
  "devDependencies": {
    "@vincle/vite-plugin-precompile": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "^7.0.1-rc",
    "vite": "catalog:"
  }
}
