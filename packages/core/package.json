{
  "name": "@vincle/core",
  "version": "1.0.0-beta.1",
  "description": "JSX-to-HTML string renderer. Zero dependencies. Fully typed.",
  "keywords": [
    "async",
    "html",
    "jsx",
    "render",
    "security",
    "ssg",
    "ssr",
    "typescript",
    "xss-prevention",
    "zero-dependency"
  ],
  "homepage": "https://vincle.cjean.fr",
  "bugs": {
    "url": "https://github.com/vincle/vincle/issues"
  },
  "license": "MIT",
  "author": "Christophe Jean",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vincle/vincle.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "jsx-global.d.ts",
    "README.md",
    "LICENSE",
    "skills"
  ],
  "type": "module",
  "sideEffects": false,
  "browser": {
    "node:async_hooks": false
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "default": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "default": "./dist/jsx-dev-runtime.js"
    },
    "./jsx-global": {
      "types": "./jsx-global.d.ts"
    },
    "./html": {
      "types": "./dist/utils/html.d.ts",
      "default": "./dist/utils/html.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pkgroll --clean-dist --minify",
    "check": "tsc --noEmit",
    "coverage": "bun test --coverage --coverage-reporter=lcov",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "mutation": "stryker run",
    "test": "bun test"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/bun": "catalog:",
    "@types/react": "catalog:",
    "fast-check": "catalog:",
    "pkgroll": "catalog:",
    "stryker-mutator-bun-runner": "^0.4.0",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@types/react": "^19"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
