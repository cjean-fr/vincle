{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "bun",
  "plugins": ["stryker-mutator-bun-runner"],
  "mutate": [
    "src/render.ts",
    "src/render-attrs.ts",
    "src/escape.ts",
    "src/context.ts",
    "src/raw.ts",
    "src/index.ts",
    "src/jsx-runtime.ts",
    "src/jsx-dev-runtime.ts",
    "src/utils/html.ts"
  ],
  "mutator": {
    "excludedMutations": [
      "BlockStatement"
    ]
  },
  "concurrency": 4,
  "coverageAnalysis": "off",
  "reporters": ["html", "clear-text", "progress"],
  "thresholds": {
    "high": 80,
    "low": 65,
    "break": 65
  },
  "testFiles": ["src/**/*.test.ts", "src/**/*.test.tsx"],
  "ignorePatterns": ["**/performance.test.{ts,tsx}", "**/memory.test.{ts,tsx}"],
  "timeoutMS": 30000
}
