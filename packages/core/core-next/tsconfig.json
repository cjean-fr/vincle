{
  "extends": "../typescript-config/react.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@vincle/core",
    "outDir": "./dist",
    "rootDir": "./",
    "paths": {
      "@vincle/core": ["./src/index.ts"],
      "@vincle/core/jsx-runtime": ["./src/jsx-runtime.ts"],
      "@vincle/core/jsx-dev-runtime": ["./src/jsx-dev-runtime.ts"],
      "@vincle/core/jsx-precompile-runtime": ["./src/jsx-precompile-runtime.ts"],
      "@vincle/core/html": ["./src/html.ts"]
    },
    "types": ["bun"]
  },
  "include": ["src"]
}
