{
  "name": "@vincle/precompile-core",
  "version": "1.0.0",
  "description": "Shared helpers for @vincle/core JSX precompile transforms",
  "keywords": [
    "ast",
    "jsx",
    "precompile",
    "transform",
    "vite"
  ],
  "homepage": "https://vincle.cjean.fr",
  "license": "MIT",
  "author": "Christophe Jean",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vincle/vincle.git",
    "directory": "packages/precompile-core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "coverage": "bun test --coverage --coverage-reporter=lcov",
    "format": "oxfmt",
    "mutation": "stryker run",
    "test": "bun test"
  },
  "dependencies": {
    "@vincle/core": "workspace:*",
    "entities": "^8.0.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/bun": "catalog:",
    "stryker-mutator-bun-runner": "^0.4.0",
    "typescript": "^7.0.1-rc"
  }
}
