{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "bun",
  "plugins": ["stryker-mutator-bun-runner"],
  "mutate": [
    "src/index.ts"
  ],
  "mutator": {
    "excludedMutations": [
      "BlockStatement",
      "BooleanLiteral",
      "ConditionalExpression",
      "EqualityOperator",
      "LogicalOperator",
      "StringLiteral",
      "UnaryOperator",
      "UpdateOperator",
      "PrefixUnaryExpression"
    ]
  },
  "concurrency": 4,
  "coverageAnalysis": "off",
  "reporters": ["html", "clear-text", "progress"],
  "thresholds": {
    "high": 90,
    "low": 75,
    "break": 75
  },
  "testFiles": ["src/**/*.test.ts", "src/**/*.test.tsx"],
  "timeoutMS": 30000
}
