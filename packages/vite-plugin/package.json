{
  "name": "@vincle/vite-plugin",
  "version": "0.9.0",
  "description": "Vite asset integration for @vincle/core",
  "keywords": [
    "asset",
    "hmr",
    "jsx",
    "manifest",
    "ssr",
    "vite",
    "vite-plugin"
  ],
  "homepage": "https://vincle.cjean.fr",
  "bugs": {
    "url": "https://github.com/vincle/vincle/issues"
  },
  "license": "MIT",
  "author": "Christophe Jean",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vincle/vincle.git",
    "directory": "packages/vite-plugin"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit",
    "format": "oxfmt",
    "test": "bun test"
  },
  "dependencies": {
    "@vincle/core": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/react": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@types/react": "^19"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
